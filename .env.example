# --- Pares monitorados (separados por vírgula) ---
# Default: só USDT/BRL. Para voltar a monitorar BTC: SYMBOLS=USDT/BRL,BTC/BRL
SYMBOLS=USDT/BRL

# --- Custos de rebalanceamento (referência) ---
# A captura pré-posicionada não paga transferência; estes valores servem
# para estimar o custo de REBALANCEAR ativamente o capital entre exchanges.
# TRC-20 é a rede mais barata aceita por todas (MB só aceita TRC-20/ERC-20).
TRANSFER_FEE_USDT=1.0

# --- Ciclo de coleta ---
POLL_INTERVAL_SECONDS=10
REQUEST_TIMEOUT_SECONDS=8
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY_SECONDS=0.5

# --- Regras de alerta ---
# Spread líquido mínimo (em %) para disparar alerta
SPREAD_THRESHOLD_PCT=0.8
# Threshold reduzido para rotas que REEQUILIBRAM o capital (movem BRL
# para a ponta que tem menos): além de lucrar, elas devolvem o inventário
# à posição de graça — vale agir com qualquer lucro positivo
REVERSE_ALERT_THRESHOLD_PCT=0.0
# Cooldown por rota (par + exchanges), em minutos
ALERT_COOLDOWN_MINUTES=15
# Capital simulado usado no VWAP e no lucro estimado (em BRL)
CAPITAL_BRL=11000

# --- Persistência e logs ---
DB_PATH=data/spreads.db
LOG_LEVEL=INFO

# --- Taxas taker por exchange (fração: 0.007 = 0,70%) ---
# Confira as taxas do seu tier em cada exchange antes de confiar nos alertas!
FEE_TAKER_MERCADO_BITCOIN=0.007
FEE_TAKER_FOXBIT=0.005
FEE_TAKER_BRASIL_BITCOIN=0.005
FEE_TAKER_BINANCE=0.001

# --- Taxa de saque BRL (PIX) por exchange: fração + fixo em BRL ---
# Cobrada na ponta de VENDA para devolver o capital à conta bancária.
# MB e Foxbit anunciam saque PIX gratuito; Brasil Bitcoin cobra 0,5% + R$1,99.
FEE_SAQUE_BRL_PCT_MERCADO_BITCOIN=0.0
FEE_SAQUE_BRL_FIXO_MERCADO_BITCOIN=0.0
FEE_SAQUE_BRL_PCT_FOXBIT=0.0
FEE_SAQUE_BRL_FIXO_FOXBIT=0.0
FEE_SAQUE_BRL_PCT_BRASIL_BITCOIN=0.005
FEE_SAQUE_BRL_FIXO_BRASIL_BITCOIN=1.99
